<configuration>
    <!--
      Тесты не должны писать в тот же файл, что и живая работа: иначе в логе
      вперемешку настоящие разговоры и заглушки из /tmp, и разобрать поведение
      бота становится нельзя. Здесь только консоль и только то, что сломалось.
    -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%-5level %logger{20} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
