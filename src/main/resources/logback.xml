<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{20} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- разбирать поведение по консоли неудобно: ход мыслей длинный и уезжает вверх -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/raine.log</file>
        <!-- и по дате, и по размеру: зациклившийся код однажды написал сюда
             гигабайт за вечер, и место кончилось бы раньше, чем это заметили -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/raine.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="it.tdlight" level="WARN"/>
    <!-- отсев входящих и замеры памяти видны только в DEBUG; включается
         по надобности: ./gradlew run -Praine.log=DEBUG -->
    <logger name="ru.rainedev.raine" level="${raine.log:-INFO}"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
